{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "cap:sync": "npx cap sync android",
        "android:icons": "npx @capacitor/assets generate --android",
