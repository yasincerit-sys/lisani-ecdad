APP_NAME="Lisanı Ecdad"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Kill switch — canlı site + APK kapalı; localhost muaf (APP_ENV=local)
LISANI_KILL_SWITCH=false
LISANI_KILL_SWITCH_ALLOW_LOCAL=true

# Android APK (Ayarlar + giriş ekranında indirme linki)
# Boş bırakılırsa public/downloads/lisani-ecdad.apk kullanılır (npm run android:publish)
LISANI_APK_URL=
LISANI_APK_FILENAME=lisani-ecdad.apk

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=lisani_ecdad
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# İsteğe bağlı: bot mesajları için OpenAI uyumlu API (Groq, OpenRouter, Ollama vb.)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
